<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ═══════════════════════════════════════════════════════
         PROPERTIES
    ═══════════════════════════════════════════════════════ -->
    <property name="APP_NAME" value="todolistapp" />
    <!-- Docker: gunakan path absolut /app/logs agar direktori selalu tersedia -->
    <property name="LOG_PATH" value="${LOG_PATH:-/app/logs}" />
    <property name="LOG_FILE" value="${LOG_PATH}/${APP_NAME}" />

    <!-- ═══════════════════════════════════════════════════════
         DEFAULT APPENDER (di luar springProfile)
         ────────────────────────────────────────────────────
         Aktif sejak startup — SEBELUM Spring membaca profile.
         Ini yang mencegah warning "No appenders present in
         context [default]" dari Logback saat boot awal.
    ═══════════════════════════════════════════════════════ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Default root — INFO ke console, aktif sampai profile override -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- ═══════════════════════════════════════════════════════
         APPENDERS PER PROFILE
    ═══════════════════════════════════════════════════════ -->

    <!-- ── CONSOLE: JSON structured (prod) ─────────
         FIX: <providers> (plural) dihapus — tidak didukung di
         logstash-logback-encoder >= 7.x. Gunakan <provider>
         (singular) per item, atau biarkan LogstashEncoder
         menggunakan default providers-nya (timestamp, level,
         logger, thread, message, mdc, stackTrace sudah
         include by default).

         Untuk custom field name, gunakan
         <fieldNames> block sebagai gantinya.
    ──────────────────────────────────────────────────────── -->
    <springProfile name="prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">

                <!-- Custom field names — pengganti <providers> lama -->
                <fieldNames>
                    <timestamp>timestamp</timestamp>
                    <level>level</level>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <message>message</message>
                    <stackTrace>stack_trace</stackTrace>
                </fieldNames>

                <!-- Format timestamp -->
                <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>

                <!-- Panjang nama logger yang dipersingkat -->
                <shortenedLoggerNameLength>36</shortenedLoggerNameLength>

                <!-- Custom field tambahan -->
                <customFields>{"app":"${APP_NAME}"}</customFields>

                <!-- Stack trace converter — pengganti <stackTrace> provider lama -->
                <throwableConverter
                    class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxLength>2048</maxLength>
                    <shortenedClassNameLength>36</shortenedClassNameLength>
                    <rootCauseFirst>true</rootCauseFirst>
                    <exclude>sun\.reflect\..*</exclude>
                    <exclude>java\.lang\.reflect\..*</exclude>
                </throwableConverter>

            </encoder>
        </appender>
    </springProfile>

    <!-- ── FILE: Rolling (dev, prod) ────────────────
         Local tidak punya file — console only
    ──────────────────────────────────────────────────────── -->
    <springProfile name="dev,prod">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_FILE}.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"app":"${APP_NAME}"}</customFields>
                <throwableConverter
                    class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxLength>2048</maxLength>
                    <shortenedClassNameLength>36</shortenedClassNameLength>
                    <rootCauseFirst>true</rootCauseFirst>
                    <exclude>sun\.reflect\..*</exclude>
                    <exclude>java\.lang\.reflect\..*</exclude>
                </throwableConverter>
            </encoder>
        </appender>

        <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="FILE" />
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <includeCallerData>false</includeCallerData>
        </appender>
    </springProfile>

    <!-- ── FILE: Error only (prod) ──────────────── -->
    <springProfile name="prod">
        <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_FILE}-error.log</file>
            <filter class="ch.qos.logback.classic.filter.LevelFilter">
                <level>ERROR</level>
                <onMatch>ACCEPT</onMatch>
                <onMismatch>DENY</onMismatch>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>${LOG_FILE}-error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
                <maxHistory>90</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"app":"${APP_NAME}"}</customFields>
                <throwableConverter
                    class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxLength>2048</maxLength>
                    <shortenedClassNameLength>36</shortenedClassNameLength>
                    <rootCauseFirst>true</rootCauseFirst>
                    <exclude>sun\.reflect\..*</exclude>
                    <exclude>java\.lang\.reflect\..*</exclude>
                </throwableConverter>
            </encoder>
        </appender>

        <appender name="ASYNC_FILE_ERROR" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="FILE_ERROR" />
            <queueSize>256</queueSize>
            <discardingThreshold>0</discardingThreshold>
        </appender>
    </springProfile>

    <!-- ═══════════════════════════════════════════════════════
         LOGGER LEVELS + ROOT PER PROFILE
    ═══════════════════════════════════════════════════════ -->

    <!-- ── LOCAL: Console only, verbose untuk debug ────────── -->
    <springProfile name="local">
        <logger name="com.mohammadnuridin.todolistapp" level="DEBUG" />
        <logger name="org.hibernate.SQL" level="DEBUG" />
        <logger name="org.hibernate.orm.jdbc.bind" level="TRACE" />
        <logger name="org.springframework.transaction" level="DEBUG" />
        <logger name="org.springframework.security" level="DEBUG" />

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>

    <!-- ── DEV: Console + File, verbose ────────────────────── -->
    <springProfile name="dev">
        <logger name="com.mohammadnuridin.todolistapp" level="DEBUG" />
        <logger name="org.hibernate.SQL" level="DEBUG" />
        <logger name="org.springframework.security" level="DEBUG" />
        <logger name="org.flywaydb" level="INFO" />

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="ASYNC_FILE" />
        </root>
    </springProfile>

    <!-- ── PROD: Console (JSON) + File + Error file ─────────── -->
    <springProfile name="prod">
        <logger name="com.mohammadnuridin.todolistapp" level="WARN" />
        <logger name="org.springframework" level="WARN" />
        <logger name="org.hibernate" level="WARN" />

        <root level="WARN">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_FILE_ERROR" />
        </root>
    </springProfile>

</configuration>